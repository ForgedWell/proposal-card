// Proposal Card - Prisma Schema
// Phase 4: Polish & launch prep

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String  @id @default(cuid())
  email     String? @unique
  phone     String? @unique

  // Profile fields
  slug        String?  @unique           // public URL: /c/[slug] (auto-generated)
  displayName String?
  bio         String?                    // legacy — replaced by structured fields
  photoUrl    String?
  location    String?                    // legacy — replaced by country/state/city
  links       Json?                      // [{ label, url }]

  // Structured profile (Phase 5)
  country        String?
  state          String?
  city           String?
  height         String?
  education      String?
  profession     String?
  religiosity    String?
  maritalHistory String?
  hasChildren    String?
  wantsChildren  String?
  languages      Json?                   // string[]
  intention      String?                 // max 140 chars

  // Identity + setup
  fullName             String?
  dateOfBirth          DateTime?
  gender               String?                       // "brother" or "sister"
  profileSetupComplete Boolean  @default(false)

  // Onboarding + role
  onboardingComplete Boolean @default(false)
  role               String  @default("user")      // user / wali / admin
  waliFor            String[]                       // user IDs this account is Guardian for

  // QR / card
  cardToken    String?       @unique           // stable token for QR code URL
  cardActive   Boolean       @default(false)   // owner must activate before going public
  cardTemplate CardTemplate  @default(CLASSIC) // card design template
  cardColor    String?                         // custom header/accent color (hex)

  // Wali (guardian) — owner can register a guardian contact for consent routing
  waliPhone   String?
  waliEmail   String?
  waliActive  Boolean  @default(false)

  // Privacy — per-field visibility toggles
  fieldVisibility Json?                    // { displayName: bool, bio: bool, location: bool, photoUrl: bool, links: bool }

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions             Session[]
  otpCodes             OtpCode[]
  cardScans            CardScan[]
  connectionRequests   ConnectionRequest[]   @relation("OwnerRequests")
  inboundRequests      ConnectionRequest[]   @relation("ProspectRequests")
  sentMessages         Message[]             @relation("SentMessages")
  receivedMessages     Message[]             @relation("ReceivedMessages")
  blocks               Block[]
  reports              Report[]
  waliNotes            WaliNote[]

  @@map("users")
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model OtpCode {
  id        String    @id @default(cuid())
  userId    String?
  target    String
  code      String
  type      OtpType
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())
  user      User?     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_codes")
}

enum OtpType {
  EMAIL
  PHONE
}

enum CardTemplate {
  CLASSIC
  MINIMAL
  ELEGANT
}

// ─── Card scans ───────────────────────────────────────────────────────────────

model CardScan {
  id        String   @id @default(cuid())
  userId    String                        // card owner
  ip        String?
  userAgent String?
  country   String?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("card_scans")
}

// ─── Connection requests (consent flow — #19) ─────────────────────────────────

model ConnectionRequest {
  id          String            @id @default(cuid())
  ownerId     String                                    // card owner
  prospectId  String?                                   // null if prospect not a user yet
  prospectName String?
  prospectContact String?                               // email or phone they provided
  intent      String?                                   // brief intro / reason
  status      ConnectionStatus  @default(PENDING)
  decidedAt   DateTime?

  // Token-based conversation
  conversationToken    String?   @unique
  tokenExpiresAt       DateTime?
  sentCountOwner       Int       @default(0)
  sentCountRequester   Int       @default(0)

  // Wali actions
  pausedBy             String?                         // "wali" or "system"
  pausedAt             DateTime?
  waliApprovedAt       DateTime?
  closedAt             DateTime?

  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt

  owner       User              @relation("OwnerRequests",    fields: [ownerId],    references: [id], onDelete: Cascade)
  prospect    User?             @relation("ProspectRequests", fields: [prospectId], references: [id], onDelete: SetNull)
  messages    Message[]
  waliNotes   WaliNote[]

  @@map("connection_requests")
}

enum ConnectionStatus {
  PENDING
  APPROVED
  PAUSED
  WALI_APPROVED
  CLOSED
  DECLINED
  BLOCKED
}

// ─── In-app messaging (#17) ───────────────────────────────────────────────────

model Message {
  id                  String            @id @default(cuid())
  connectionRequestId String
  senderId            String
  recipientId         String
  senderRole          String?                             // "owner" or "requester" — for pre-account disambiguation
  body                String
  readAt              DateTime?
  createdAt           DateTime          @default(now())

  connectionRequest   ConnectionRequest @relation(fields: [connectionRequestId], references: [id], onDelete: Cascade)
  sender              User              @relation("SentMessages",     fields: [senderId],    references: [id], onDelete: Cascade)
  recipient           User              @relation("ReceivedMessages", fields: [recipientId], references: [id], onDelete: Cascade)

  @@map("messages")
}

// ─── Wali notes ──────────────────────────────────────────────────────────────

model WaliNote {
  id                  String            @id @default(cuid())
  connectionRequestId String
  waliId              String
  content             String                              // max 300 chars
  createdAt           DateTime          @default(now())

  connectionRequest   ConnectionRequest @relation(fields: [connectionRequestId], references: [id], onDelete: Cascade)
  wali                User              @relation(fields: [waliId], references: [id], onDelete: Cascade)

  @@map("wali_notes")
}

// ─── SMS alert rate limiting ─────────────────────────────────────────────────

model SmsAlert {
  id                  String   @id @default(cuid())
  waliId              String
  connectionRequestId String?
  alertType           String
  sentAt              DateTime @default(now())

  @@index([waliId, connectionRequestId, alertType, sentAt])
  @@map("sms_alerts")
}

// ─── Safety: Blocking (#9) ──────────────────────────────────────────────────

model Block {
  id        String   @id @default(cuid())
  ownerId   String                          // user who blocked
  contact   String                          // blocked email or phone
  reason    String?
  createdAt DateTime @default(now())
  owner     User     @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  @@unique([ownerId, contact])
  @@map("blocks")
}

// ─── Safety: Reporting (#9) ─────────────────────────────────────────────────

model Report {
  id                  String         @id @default(cuid())
  reporterId          String
  connectionRequestId String?
  contact             String?
  category            ReportCategory
  details             String?
  createdAt           DateTime       @default(now())
  reporter            User           @relation(fields: [reporterId], references: [id], onDelete: Cascade)

  @@map("reports")
}

enum ReportCategory {
  SPAM
  HARASSMENT
  INAPPROPRIATE
  OTHER
}

// ─── Safety: Rate limiting (#10) ────────────────────────────────────────────

model ContactAttempt {
  id        String   @id @default(cuid())
  ownerId   String                          // target card owner
  ip        String?
  contact   String?                         // requester email/phone
  createdAt DateTime @default(now())

  @@index([ownerId, ip, createdAt])
  @@index([ownerId, contact, createdAt])
  @@map("contact_attempts")
}
